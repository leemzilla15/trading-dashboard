{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://trading-dashboard-1-dfo6.onrender.com/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
